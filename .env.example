# SMTP config for the /api/contact serverless function (Brevo).
# These vars are SERVER-SIDE ONLY — do NOT prefix with VITE_ (would expose them to the browser).
# In production, set these in Vercel: Project → Settings → Environment Variables.

MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_smtp_login
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_FROM_ADDRESS=no-reply@your-domain.tld
MAIL_FROM_NAME=My Portfolio
MAIL_TO=where_to_receive_messages@example.com

# --- CMS: database + admin auth (server-side only) ---
# Neon Postgres pooled connection string (Project → Connection Details).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign the admin session JWT. Generate: openssl rand -base64 32
AUTH_SECRET=change_me_to_a_long_random_string

# The single admin account allowed into /admin.
ADMIN_EMAIL=you@example.com
# bcrypt hash of your admin password. Generate:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" "yourPassword"
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
